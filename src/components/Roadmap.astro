---
import IslandStage from "./IslandStage.astro";

type Stage = {
  id?: string;
  title: string;
  summary?: string;
  subtopics?: Stage[];
};

const { roadmap } = Astro.props as {
  roadmap: {
    title: string;
    stages: Stage[];
  };
};

const titleCharacters = Array.from(roadmap.title);
---

<main class="page-shell">
  <div class="product-workspace" id="top">
    <section class="roadmap-board" aria-label={roadmap.title}>
      <div class="roadmap-title">
        <div class="roadmap-title-copy">
          <h1 class="blur-title" aria-label={roadmap.title}>
            {titleCharacters.map((character, index) => (
              <span
                class={`blur-title-char${character === " " ? " is-space" : ""}`}
                style={`--char-index: ${index}`}
                aria-hidden="true"
              >
                {character === " " ? "\u00A0" : character}
              </span>
            ))}
          </h1>
        </div>
      </div>

      <div class="roadmap-flow">
        {roadmap.stages.map((stage, index: number) => (
          <IslandStage stage={stage} index={index} isLast={index === roadmap.stages.length - 1} />
        ))}
      </div>
    </section>

    <aside class="detail-dock" aria-label="阶段详情"></aside>
  </div>

  <button
    class="intro-scrim"
    type="button"
    aria-label="关闭详情页"
    aria-hidden="true"
    tabindex="-1"
    data-intro-close-overlay
  ></button>

  <div
    class="panel-load-error"
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    hidden
    data-panel-load-error
  >
    <span data-panel-load-error-message>详情暂时加载失败，请检查网络后重试。</span>
    <button type="button" data-panel-load-retry>重试</button>
  </div>
</main>

<script>
  type IntroSection = {
    title: string;
    paragraphs: string[];
  };

  type Resource = {
    label: string;
    url: string;
    note?: string;
  };

  type Group = {
    title: string;
    description?: string | string[];
    items?: string[];
    toolResources?: Resource[];
    resources?: Resource[];
  };

  type ThemeColor = "gray" | "blue" | "green" | "amber" | "coral";

  type Subtopic = {
    id: string;
    title: string;
    color?: ThemeColor;
  };

  type PanelParent = {
    id: string;
    title: string;
  };

  type PanelData = {
    id: string;
    parent?: PanelParent;
    title?: string;
    summary?: string;
    sections?: IntroSection[];
    groups?: Group[];
    subtopics?: Subtopic[];
  };

  type PanelMap = Record<string, PanelData>;

  type RoadmapHistoryState = {
    panelId: string | null;
    depth: number;
    stackId: string;
  };

  const setupStagePanels = () => {
    const PANEL_DATA_URL = "/roadmap-data.json";
    const HISTORY_STATE_KEY = "__aiRoadmap";
    const mobileQuery = window.matchMedia("(max-width: 900px)");
    const overlay = document.querySelector<HTMLButtonElement>("[data-intro-close-overlay]");
    const workspace = document.querySelector<HTMLElement>(".product-workspace");
    const roadmapBoard = document.querySelector<HTMLElement>(".roadmap-board");
    const detailDock = document.querySelector<HTMLElement>(".detail-dock");
    const loadError = document.querySelector<HTMLElement>("[data-panel-load-error]");
    const loadErrorMessage = document.querySelector<HTMLElement>("[data-panel-load-error-message]");
    const retryButton = document.querySelector<HTMLButtonElement>("[data-panel-load-retry]");
    let lockedScrollY = 0;
    let panelDataPromise: Promise<PanelMap> | null = null;
    let focusRestoreTrigger: HTMLButtonElement | null = null;
    let pendingRetry: {
      panelId: string;
      trigger: HTMLButtonElement | null;
      syncHistory: boolean;
    } | null = null;
    let historyUnwindPending = false;
    let historyUnwindTimer = 0;
    let panelOpenRequestId = 0;

    const getPanels = () => Array.from(document.querySelectorAll<HTMLElement>("[data-intro-panel]"));
    const getTriggers = () => Array.from(document.querySelectorAll<HTMLButtonElement>("[data-intro-trigger]"));
    const getOpenPanel = () => getPanels().find((panel) => panel.dataset.open === "true") ?? null;

    const getRoadmapHistoryState = (state: unknown = window.history.state): RoadmapHistoryState | null => {
      if (!state || typeof state !== "object") return null;
      const candidate = (state as Record<string, unknown>)[HISTORY_STATE_KEY];
      if (!candidate || typeof candidate !== "object") return null;

      const { panelId, depth, stackId } = candidate as Partial<RoadmapHistoryState>;
      if ((panelId !== null && typeof panelId !== "string") || !Number.isInteger(depth) || (depth ?? -1) < 0) {
        return null;
      }
      if (typeof stackId !== "string" || !stackId) return null;

      return { panelId: panelId ?? null, depth: depth as number, stackId };
    };

    const createHistoryStackId = () =>
      window.crypto.randomUUID?.() ?? `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}`;

    const mergeRoadmapHistoryState = (roadmapState: RoadmapHistoryState) => {
      const currentState = window.history.state;
      const preservedState =
        currentState && typeof currentState === "object" && !Array.isArray(currentState)
          ? (currentState as Record<string, unknown>)
          : {};
      return { ...preservedState, [HISTORY_STATE_KEY]: roadmapState };
    };

    const replaceRoadmapHistoryState = (roadmapState: RoadmapHistoryState) => {
      window.history.replaceState(mergeRoadmapHistoryState(roadmapState), "");
    };

    const pushRoadmapHistoryState = (roadmapState: RoadmapHistoryState) => {
      window.history.pushState(mergeRoadmapHistoryState(roadmapState), "");
    };

    const setTriggerLoading = (trigger: HTMLButtonElement | null | undefined, isLoading: boolean) => {
      if (!trigger?.hasAttribute("data-intro-trigger")) return;
      trigger.toggleAttribute("data-loading", isLoading);
      if (isLoading) {
        trigger.setAttribute("aria-busy", "true");
      } else {
        trigger.removeAttribute("aria-busy");
      }
    };

    const clearLoadError = () => {
      pendingRetry = null;
      if (loadError) loadError.hidden = true;
    };

    const showLoadError = (panelId: string, trigger: HTMLButtonElement | null, syncHistory: boolean) => {
      pendingRetry = { panelId, trigger, syncHistory };
      if (loadErrorMessage) {
        loadErrorMessage.textContent = "详情暂时加载失败，请检查网络后重试。";
      }
      if (loadError) loadError.hidden = false;
    };

    const getSafeExternalUrl = (value: string) => {
      try {
        const url = new URL(value.trim());
        return url.protocol === "https:" ? url.href : null;
      } catch {
        return null;
      }
    };

    const createElement = <K extends keyof HTMLElementTagNameMap>(
      tagName: K,
      className?: string,
      textContent?: string
    ) => {
      const element = document.createElement(tagName);
      if (className) element.className = className;
      if (typeof textContent === "string") element.textContent = textContent;
      return element;
    };

    const createLinkedParagraph = (text: string) => {
      const paragraph = createElement("p");
      const contactEmail = "heheer@zju.edu.cn";
      const parts = text.split(contactEmail);

      parts.forEach((part, index) => {
        if (part) paragraph.append(document.createTextNode(part));
        if (index < parts.length - 1) {
          const link = document.createElement("a");
          link.href = `mailto:${contactEmail}`;
          link.textContent = contactEmail;
          paragraph.append(link);
        }
      });

      return paragraph;
    };

    const createSvg = (pathValue: string, className?: string) => {
      const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      if (className) svg.setAttribute("class", className);
      svg.setAttribute("aria-hidden", "true");
      svg.setAttribute("viewBox", "0 0 24 24");
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      path.setAttribute("d", pathValue);
      svg.append(path);
      return svg;
    };

    const splitResourceLabel = (label: string) => {
      const separator = " / ";

      if (!label.includes(separator)) {
        return { title: label };
      }

      const [source, ...titleParts] = label.split(separator);
      const title = titleParts.join(separator).trim();

      if (!title) {
        return { title: label };
      }

      return {
        source: source.trim(),
        title
      };
    };

    const renderResourceList = (resources: Resource[]) => {
      const list = createElement("ul", "resource-list");
      const isCompactToolList = resources.length > 1 && resources.every((resource) => !resource.note);

      if (isCompactToolList) {
        list.classList.add("resource-list-compact");
      }

      resources.forEach((resource) => {
        const listItem = document.createElement("li");
        const safeUrl = getSafeExternalUrl(resource.url);
        const resourceLabel = splitResourceLabel(resource.label);
        const content = createElement("span", "resource-link-content");
        content.append(createElement("span", "resource-link-title", resourceLabel.title));
        if (resourceLabel.source) {
          content.append(createElement("span", "resource-link-source", resourceLabel.source));
        }
        if (resource.note) {
          content.append(createElement("span", "resource-link-note", resource.note));
        }

        if (safeUrl) {
          const link = document.createElement("a");
          link.href = safeUrl;
          link.target = "_blank";
          link.rel = "noopener noreferrer external";
          link.append(content, createSvg("M7 17 17 7M9 7h8v8"));
          listItem.append(link);
        } else {
          const unavailable = createElement("span", "resource-link-unavailable");
          unavailable.append(content);
          listItem.append(unavailable);
        }

        list.append(listItem);
      });

      return list;
    };

    const renderStageGroups = (panelData: PanelData) => {
      const stageGroups = createElement("div", "stage-groups");

      if (panelData.subtopics?.length) {
        const capabilityCard = createElement("section", "group-card capability-card");
        const capabilityGrid = createElement("div", "capability-grid");
        panelData.subtopics.forEach((topic) => {
          const button = createElement("button", `capability-button tone-${topic.color || "green"}`) as HTMLButtonElement;
          button.type = "button";
          button.setAttribute("aria-expanded", "false");
          button.setAttribute("aria-controls", `intro-panel-${topic.id}`);
          button.dataset.introTrigger = "";
          button.textContent = topic.title;
          capabilityGrid.append(button);
        });

        capabilityCard.append(capabilityGrid);
        stageGroups.append(capabilityCard);
      }

      const groupCount = panelData.groups?.length ?? 0;

      panelData.groups?.forEach((group, index) => {
        const hasResources = Boolean(group.resources?.length || group.toolResources?.length);
        const groupCard = createElement("section", `group-card ${hasResources ? "resource-group-card" : ""}`);

        if (!hasResources || groupCount > 1) {
          const heading = createElement("div", "group-card-heading");
          heading.append(createElement("h2", undefined, group.title));
          groupCard.append(heading);
        }

        if (group.description) {
          const description = createElement("div", "group-description");
          const paragraphs = Array.isArray(group.description) ? group.description : [group.description];
          paragraphs.forEach((paragraph) => description.append(createElement("p", undefined, paragraph)));
          groupCard.append(description);
        }

        if (group.items?.length) {
          const chipGrid = createElement("div", "chip-grid");
          group.items.forEach((item) => chipGrid.append(createElement("span", undefined, item)));
          groupCard.append(chipGrid);
        }

        if (group.toolResources?.length) {
          const toolPanel = createElement("div", "resource-panel is-compact");
          toolPanel.id = `${panelData.id || "stage"}-${index}-tools`;
          toolPanel.append(renderResourceList(group.toolResources));
          groupCard.append(toolPanel);
        }

        if (group.resources?.length) {
          const resourcePanel = createElement("div", "resource-panel");
          if (group.resources.length > 1 && group.resources.every((resource) => !resource.note)) {
            resourcePanel.classList.add("is-compact");
          }
          resourcePanel.id = `${panelData.id || "stage"}-${index}-resources`;
          resourcePanel.append(renderResourceList(group.resources));
          groupCard.append(resourcePanel);
        }

        stageGroups.append(groupCard);
      });

      return stageGroups;
    };

    const renderPanel = (panelData: PanelData) => {
      const panel = createElement("section", "intro-popover");
      if (panelData.sections?.length) panel.classList.add("is-article-panel");
      panel.id = panelData.id;
      panel.dataset.introPanel = "";
      panel.dataset.open = "false";
      if (panelData.parent) panel.dataset.parentPanelId = panelData.parent.id;
      panel.setAttribute("aria-hidden", "true");
      panel.setAttribute("role", "region");
      panel.inert = true;

      const closeButton = createElement("button", "intro-popover-close") as HTMLButtonElement;
      closeButton.type = "button";
      closeButton.setAttribute("aria-label", "收起详情侧边栏");
      closeButton.dataset.introClose = "";
      closeButton.append(createSvg("m6 6 12 12M18 6 6 18"));

      const body = createElement("div", "intro-popover-body");

      if (panelData.parent) {
        const backButton = createElement("button", "panel-back-button") as HTMLButtonElement;
        backButton.type = "button";
        backButton.dataset.introBack = "";
        backButton.setAttribute("aria-controls", panelData.parent.id);
        backButton.setAttribute("aria-label", `返回${panelData.parent.title}`);
        const arrow = createElement("span", "panel-back-arrow", "‹");
        arrow.setAttribute("aria-hidden", "true");
        backButton.append(arrow, createElement("span", undefined, panelData.parent.title));
        body.append(backButton);
      }

      if (panelData.title || panelData.summary) {
        const overview = createElement("section", "intro-section intro-overview");
        if (panelData.title) {
          const title = createElement("h2", undefined, panelData.title);
          title.id = `${panelData.id}-title`;
          title.tabIndex = -1;
          panel.setAttribute("aria-labelledby", title.id);
          overview.append(title);
        } else {
          panel.setAttribute("aria-label", "阶段详情");
        }
        if (panelData.summary) overview.append(createElement("p", "intro-lead", panelData.summary));
        body.append(overview);
      }

      panelData.sections?.forEach((section) => {
        const sectionNode = createElement("section", "intro-section intro-essay");
        const heading = createElement("div", "intro-section-heading");
        heading.append(createElement("h2", undefined, section.title));
        sectionNode.append(heading);

        const paragraphStack = createElement("div", "intro-paragraph-stack");
        section.paragraphs.forEach((paragraph) => {
          paragraphStack.append(createLinkedParagraph(paragraph));
        });
        sectionNode.append(paragraphStack);

        body.append(sectionNode);
      });

      if ((panelData.groups?.length || 0) > 0 || (panelData.subtopics?.length || 0) > 0) {
        body.append(renderStageGroups(panelData));
      }

      panel.append(closeButton, body);
      return panel;
    };

    const loadPanelData = async () => {
      if (!panelDataPromise) {
        panelDataPromise = fetch(PANEL_DATA_URL, { credentials: "same-origin" })
          .then(async (response) => {
            if (!response.ok) {
              throw new Error(`Failed to load panel data: ${response.status}`);
            }

            return response.json() as Promise<PanelMap>;
          })
          .catch((error) => {
            panelDataPromise = null;
            throw error;
          });
      }

      return panelDataPromise;
    };

    const ensurePanel = async (panelId: string) => {
      const existingPanel = document.getElementById(panelId);
      if (existingPanel) return existingPanel as HTMLElement;
      if (!detailDock) return null;

      const panelDataMap = await loadPanelData();
      const panelData = panelDataMap[panelId];
      if (!panelData) return null;

      const panel = renderPanel(panelData);
      detailDock.append(panel);
      return panel;
    };

    const unlockPage = () => {
      if (document.body.dataset.drawerLocked !== "true") return;
      document.body.dataset.drawerLocked = "false";
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.width = "";
      document.documentElement.style.overflow = "";
      window.scrollTo(0, lockedScrollY);
    };

    const lockPage = () => {
      if (!mobileQuery.matches || document.body.dataset.drawerLocked === "true") return;
      lockedScrollY = window.scrollY;
      document.body.dataset.drawerLocked = "true";
      document.body.style.position = "fixed";
      document.body.style.top = `-${lockedScrollY}px`;
      document.body.style.width = "100%";
      document.documentElement.style.overflow = "hidden";
    };

    const configurePanelMode = (panel: HTMLElement, isMobile: boolean) => {
      panel.setAttribute("role", isMobile ? "dialog" : "region");
      if (isMobile) {
        panel.setAttribute("aria-modal", "true");
      } else {
        panel.removeAttribute("aria-modal");
      }
    };

    const getFocusableElements = (panel: HTMLElement) =>
      Array.from(
        panel.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((element) => !element.inert && element.getClientRects().length > 0);

    const closeAll = (restoreFocus = false, suppressFocusRestore = false) => {
      const triggers = getTriggers();
      const panels = getPanels();
      const activeElement = document.activeElement as HTMLElement | null;
      const focusWasInsidePanel = panels.some((panel) => activeElement && panel.contains(activeElement));
      const focusTarget = focusRestoreTrigger;

      panels.forEach((panel) => {
        panel.dataset.open = "false";
        panel.classList.remove("is-open");
        panel.setAttribute("aria-hidden", "true");
        panel.removeAttribute("aria-modal");
        panel.setAttribute("role", "region");
        panel.inert = true;
      });
      triggers.forEach((trigger) => trigger.setAttribute("aria-expanded", "false"));
      document.querySelectorAll(".island-stage.is-active").forEach((stage) => stage.classList.remove("is-active"));
      document.body.dataset.introDrawerOpen = "false";
      if (roadmapBoard) roadmapBoard.inert = false;
      workspace?.classList.remove("is-detail-open");
      overlay?.setAttribute("aria-hidden", "true");
      if (overlay) overlay.tabIndex = -1;
      unlockPage();
      if (!suppressFocusRestore && (restoreFocus || focusWasInsidePanel)) {
        focusTarget?.focus({ preventScroll: true });
      }
      focusRestoreTrigger = null;
    };

    const hasOpenPanel = () => Boolean(getOpenPanel());

    const syncRoadmapHistoryAfterOpen = (
      panelId: string,
      sourceWasInsidePanel: boolean,
      hadOpenPanel: boolean
    ) => {
      if (!mobileQuery.matches) return;

      const currentState = getRoadmapHistoryState();
      if (!hadOpenPanel || !currentState || currentState.depth === 0) {
        const stackId = currentState?.depth === 0 ? currentState.stackId : createHistoryStackId();
        if (!currentState || currentState.depth !== 0) {
          replaceRoadmapHistoryState({ panelId: null, depth: 0, stackId });
        }
        pushRoadmapHistoryState({ panelId, depth: 1, stackId });
        return;
      }

      const nextState = {
        panelId,
        depth: sourceWasInsidePanel ? currentState.depth + 1 : currentState.depth,
        stackId: currentState.stackId,
      };
      if (sourceWasInsidePanel) {
        pushRoadmapHistoryState(nextState);
      } else {
        replaceRoadmapHistoryState(nextState);
      }
    };

    const clearHistoryUnwind = () => {
      historyUnwindPending = false;
      if (historyUnwindTimer) window.clearTimeout(historyUnwindTimer);
      historyUnwindTimer = 0;
    };

    const unwindRoadmapHistory = (restoreFocus = true) => {
      const currentState = getRoadmapHistoryState();
      panelOpenRequestId += 1;
      closeAll(restoreFocus);
      if (!currentState || currentState.depth === 0) return;

      historyUnwindPending = true;
      window.history.go(-currentState.depth);
      historyUnwindTimer = window.setTimeout(() => {
        if (!historyUnwindPending) return;
        const staleState = getRoadmapHistoryState();
        if (staleState?.stackId === currentState.stackId && staleState.depth > 0) {
          replaceRoadmapHistoryState({ panelId: null, depth: 0, stackId: currentState.stackId });
        }
        clearHistoryUnwind();
      }, 700);
    };

    const openPanelById = async (
      panelId: string,
      activeTrigger?: HTMLButtonElement | null,
      syncHistory = true
    ) => {
      const requestId = ++panelOpenRequestId;
      setTriggerLoading(activeTrigger, true);

      try {
        const panel = await ensurePanel(panelId);
        if (requestId !== panelOpenRequestId) return false;
        if (!panel) throw new Error(`Panel not found: ${panelId}`);

        clearLoadError();
        const sourceWasInsidePanel = Boolean(activeTrigger?.closest("[data-intro-panel]"));
        const hadOpenPanel = hasOpenPanel();
        closeAll(false, true);
        panel.dataset.open = "true";
        panel.classList.add("is-open");
        panel.setAttribute("aria-hidden", "false");
        panel.inert = false;
        configurePanelMode(panel, mobileQuery.matches);

        const stagePanelId = panel.dataset.parentPanelId || panelId;
        const stageTrigger = getTriggers().find((candidate) => candidate.getAttribute("aria-controls") === stagePanelId);
        focusRestoreTrigger = stageTrigger ?? null;
        stageTrigger?.setAttribute("aria-expanded", "true");
        stageTrigger?.closest(".island-stage")?.classList.add("is-active");
        if (activeTrigger?.hasAttribute("data-intro-trigger")) {
          activeTrigger.setAttribute("aria-expanded", "true");
        }

        workspace?.classList.add("is-detail-open");
        panel.querySelector<HTMLElement>(".intro-popover-body")?.scrollTo({ top: 0 });

        if (mobileQuery.matches) {
          document.body.dataset.introDrawerOpen = "true";
          if (roadmapBoard) roadmapBoard.inert = true;
          overlay?.setAttribute("aria-hidden", "false");
          if (overlay) overlay.tabIndex = 0;
          lockPage();
        }

        if (syncHistory) {
          syncRoadmapHistoryAfterOpen(panelId, sourceWasInsidePanel, hadOpenPanel);
        }

        if (mobileQuery.matches || sourceWasInsidePanel) {
          requestAnimationFrame(() => {
            const focusTarget =
              panel.querySelector<HTMLElement>("[data-intro-back]") ??
              panel.querySelector<HTMLElement>("[data-intro-close]");
            focusTarget?.focus({ preventScroll: true });
          });
        }
        return true;
      } catch {
        if (requestId === panelOpenRequestId) {
          showLoadError(
            panelId,
            activeTrigger?.hasAttribute("data-intro-trigger") ? activeTrigger : null,
            syncHistory
          );
        }
        return false;
      } finally {
        setTriggerLoading(activeTrigger, false);
      }
    };

    const openPanel = async (trigger: HTMLButtonElement) => {
      if (trigger.hasAttribute("data-loading")) return;
      const panelId = trigger.getAttribute("aria-controls");
      const alreadyOpen = trigger.getAttribute("aria-expanded") === "true";

      if (alreadyOpen) {
        unwindRoadmapHistory(false);
        return;
      }

      if (!panelId) return;

      await openPanelById(panelId, trigger);
    };

    document.addEventListener("click", (event) => {
      const target = event.target as HTMLElement | null;
      const backButton = target?.closest<HTMLButtonElement>("[data-intro-back]");
      if (backButton) {
        const panelId = backButton.getAttribute("aria-controls");
        const historyState = getRoadmapHistoryState();
        if (mobileQuery.matches && historyState && historyState.depth > 1) {
          window.history.back();
        } else if (panelId) {
          void openPanelById(panelId, backButton, !mobileQuery.matches);
        }
        return;
      }

      const trigger = target?.closest<HTMLButtonElement>("[data-intro-trigger]");
      if (trigger) {
        void openPanel(trigger);
        return;
      }

      if (target?.closest("[data-intro-close]")) {
        unwindRoadmapHistory(true);
        return;
      }

      if (!mobileQuery.matches && hasOpenPanel() && !target?.closest(".detail-dock")) {
        unwindRoadmapHistory(false);
      }
    });

    overlay?.addEventListener("click", () => unwindRoadmapHistory(true));
    retryButton?.addEventListener("click", () => {
      if (!pendingRetry) return;
      const { panelId, trigger, syncHistory } = pendingRetry;
      void openPanelById(panelId, trigger, syncHistory);
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && hasOpenPanel()) {
        unwindRoadmapHistory(true);
        return;
      }

      if (event.key !== "Tab" || !mobileQuery.matches) return;
      const activePanel = getOpenPanel();
      if (!activePanel) return;
      const focusableElements = getFocusableElements(activePanel);
      if (!focusableElements.length) return;

      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];
      const activeElement = document.activeElement;

      if (event.shiftKey && (activeElement === firstElement || !activePanel.contains(activeElement))) {
        event.preventDefault();
        lastElement.focus();
      } else if (!event.shiftKey && activeElement === lastElement) {
        event.preventDefault();
        firstElement.focus();
      }
    });

    window.addEventListener("popstate", (event) => {
      const historyState = getRoadmapHistoryState(event.state);

      if (historyUnwindPending) {
        clearHistoryUnwind();
        closeAll(false);
        return;
      }

      if (historyState?.panelId && historyState.depth > 0) {
        void openPanelById(historyState.panelId, null, false);
        return;
      }

      panelOpenRequestId += 1;
      closeAll(true);
    });

    const syncViewport = (event?: MediaQueryListEvent) => {
      const panels = getPanels();
      const triggers = getTriggers();

      if (mobileQuery.matches) {
        if (event) {
          unwindRoadmapHistory(false);
        } else {
          panelOpenRequestId += 1;
          closeAll(false);
        }
        return;
      }
      unlockPage();
      const activePanel = panels.find((panel) => panel.dataset.open === "true");
      if (activePanel) {
        activePanel.inert = false;
        configurePanelMode(activePanel, false);
        const activeTrigger = triggers.find((trigger) => trigger.getAttribute("aria-controls") === activePanel.id);
        activeTrigger?.setAttribute("aria-expanded", "true");
        activeTrigger?.closest(".island-stage")?.classList.add("is-active");
        workspace?.classList.add("is-detail-open");
      } else {
        workspace?.classList.remove("is-detail-open");
      }
    };

    mobileQuery.addEventListener("change", syncViewport);
    const requestIdle = window.requestIdleCallback?.bind(window);
    if (requestIdle) {
      requestIdle(() => {
        void loadPanelData().catch(() => undefined);
      }, { timeout: 1500 });
    } else {
      setTimeout(() => {
        void loadPanelData().catch(() => undefined);
      }, 600);
    }

    syncViewport();

    const navigationEntry = performance.getEntriesByType("navigation")[0] as
      | PerformanceNavigationTiming
      | undefined;
    const initialHistoryState = getRoadmapHistoryState();
    if (navigationEntry?.type === "reload" && initialHistoryState && initialHistoryState.depth > 0) {
      window.setTimeout(() => unwindRoadmapHistory(false), 0);
    } else if (initialHistoryState?.panelId && initialHistoryState.depth > 0) {
      window.setTimeout(() => {
        void openPanelById(initialHistoryState.panelId as string, null, false);
      }, 0);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupStagePanels, { once: true });
  } else {
    setupStagePanels();
  }
</script>
