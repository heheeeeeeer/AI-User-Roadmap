---
type Resource = {
  label: string;
  url: string;
  note?: string;
};

const { resources = [] } = Astro.props as { resources?: Resource[] };

const isCompactToolList = resources.length > 1 && resources.every((resource) => !resource.note);

const getSafeExternalUrl = (value: string) => {
  try {
    const url = new URL(value);
    return url.protocol === "http:" || url.protocol === "https:" ? url.href : null;
  } catch {
    return null;
  }
};

const splitResourceLabel = (label: string) => {
  const separator = " / ";

  if (!label.includes(separator)) {
    return { title: label };
  }

  const [source, ...titleParts] = label.split(separator);
  const title = titleParts.join(separator).trim();

  if (!title) {
    return { title: label };
  }

  return {
    source: source.trim(),
    title
  };
};
---

<ul class:list={["resource-list", { "resource-list-compact": isCompactToolList }]}>
  {resources.map((resource) => {
    const safeUrl = getSafeExternalUrl(resource.url);
    const resourceLabel = splitResourceLabel(resource.label);

    return (
      <li>
        {safeUrl ? (
          <a href={safeUrl} target="_blank" rel="noopener noreferrer external">
            <span class="resource-link-content">
              <span class="resource-link-title">{resourceLabel.title}</span>
              {resourceLabel.source && <span class="resource-link-source">{resourceLabel.source}</span>}
              {resource.note && <span class="resource-link-note">{resource.note}</span>}
            </span>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="M7 17 17 7M9 7h8v8" />
            </svg>
          </a>
        ) : (
          <span class="resource-link-unavailable">
            <span class="resource-link-content">
              <span class="resource-link-title">{resourceLabel.title}</span>
              {resourceLabel.source && <span class="resource-link-source">{resourceLabel.source}</span>}
              {resource.note && <span class="resource-link-note">{resource.note}</span>}
            </span>
          </span>
        )}
      </li>
    );
  })}
</ul>
