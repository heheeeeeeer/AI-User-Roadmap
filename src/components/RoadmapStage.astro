---
import StagePanel from "./StagePanel.astro";

type IntroSection = {
  title: string;
  paragraphs: string[];
};

type Stage = {
  id?: string;
  side: string;
  color: string;
  title: string;
  intro?: IntroSection[];
  drawer?: boolean;
  groups?: any[];
  subtopics?: any[];
};

const { stage, index } = Astro.props as {
  stage: Stage;
  index: number;
};
const isLeft = stage.side === "left";
const hasIntro = Boolean(stage.intro?.length);
const hasDrawer = hasIntro || Boolean(stage.drawer);
const introPanelId = `intro-panel-${stage.id || index}`;
const isEmpty = !hasDrawer && (!stage.groups || stage.groups.length === 0) && (!stage.subtopics || stage.subtopics.length === 0);
---

<article class={`roadmap-stage ${isLeft ? "is-left" : "is-right"} ${hasDrawer ? "has-intro has-drawer" : ""} ${isEmpty ? "is-empty" : ""}`} style={`--stage-index:${index};`}>
  <div class="stage-side stage-panel">
    {isLeft && !isEmpty && !hasDrawer && <StagePanel stage={stage} />}
  </div>

  <div class="stage-spine">
    {hasDrawer ? (
      <button
        class={`stage-node stage-node-button tone-${stage.color}`}
        type="button"
        aria-expanded="false"
        aria-controls={introPanelId}
        data-intro-trigger
      >
        {stage.title}
      </button>
    ) : (
      <div class={`stage-node tone-${stage.color}`}>
        {stage.title}
      </div>
    )}
  </div>

  <div class="stage-side stage-panel">
    {!hasDrawer && !isLeft && !isEmpty && <StagePanel stage={stage} />}
  </div>
</article>

<script>
  const setupIntroPanels = () => {
    document.querySelectorAll("[data-intro-trigger]").forEach((triggerElement) => {
      const trigger = triggerElement as HTMLButtonElement;
      const panelId = trigger.getAttribute("aria-controls");
      const panel = panelId ? document.getElementById(panelId) : null;

      if (!panel || trigger.dataset.enhanced === "true") {
        return;
      }

      trigger.dataset.enhanced = "true";
      let lockedScrollY = 0;

      const setOpen = (isOpen: boolean) => {
        const board = document.querySelector(".roadmap-board") as HTMLElement | null;
        const overlay = document.querySelector("[data-intro-close-overlay]") as HTMLButtonElement | null;
        const isCurrentPanelOpen = trigger.getAttribute("aria-expanded") === "true" || panel.dataset.open === "true";
        const wasDrawerOpen = document.body.dataset.introDrawerOpen === "true";

        if (!isOpen && !isCurrentPanelOpen) {
          return;
        }

        if (isOpen) {
          document.querySelectorAll("[data-intro-panel]").forEach((panelElement) => {
            if (panelElement === panel) {
              return;
            }

            const otherPanel = panelElement as HTMLElement;
            otherPanel.dataset.open = "false";
            otherPanel.setAttribute("aria-hidden", "true");
            otherPanel.classList.remove("is-open");
            otherPanel.style.opacity = "0";
            otherPanel.style.pointerEvents = "none";
            otherPanel.style.transform = "translateX(100%)";
            otherPanel.style.boxShadow = "none";
          });
          document.querySelectorAll("[data-intro-trigger]").forEach((otherTrigger) => {
            if (otherTrigger !== trigger) {
              otherTrigger.setAttribute("aria-expanded", "false");
            }
          });
        }

        trigger.setAttribute("aria-expanded", String(isOpen));
        panel.dataset.open = String(isOpen);
        panel.setAttribute("aria-hidden", String(!isOpen));
        panel.classList.toggle("is-open", isOpen);
        panel.style.opacity = isOpen ? "1" : "0";
        panel.style.pointerEvents = isOpen ? "auto" : "none";
        panel.style.transform = isOpen ? "translateX(0)" : "translateX(100%)";
        panel.style.boxShadow = isOpen
          ? "-1px 0 0 rgb(255 255 255 / 72%) inset, -28px 0 80px rgb(39 35 28 / 14%)"
          : "none";
        if (board) {
          board.style.filter = isOpen ? "saturate(0.82) brightness(0.88)" : "";
        }
        if (overlay) {
          overlay.setAttribute("aria-hidden", String(!isOpen));
          overlay.tabIndex = isOpen ? 0 : -1;
          overlay.style.opacity = isOpen ? "1" : "0";
          overlay.style.pointerEvents = isOpen ? "auto" : "none";
        }
        document.body.dataset.introDrawerOpen = String(isOpen);
        if (isOpen) {
          lockedScrollY = wasDrawerOpen
            ? Number(document.body.dataset.lockedScrollY || lockedScrollY || 0)
            : window.scrollY;
          document.body.dataset.lockedScrollY = String(lockedScrollY);
          document.body.style.overflow = "hidden";
          document.body.style.position = "fixed";
          document.body.style.top = `-${lockedScrollY}px`;
          document.body.style.left = "0";
          document.body.style.right = "0";
          document.body.style.width = "100%";
          document.documentElement.style.overflow = "hidden";
        } else {
          lockedScrollY = Number(document.body.dataset.lockedScrollY || lockedScrollY || 0);
          document.body.style.overflow = "";
          document.body.style.position = "";
          document.body.style.top = "";
          document.body.style.left = "";
          document.body.style.right = "";
          document.body.style.width = "";
          document.body.removeAttribute("data-locked-scroll-y");
          document.documentElement.style.overflow = "";
          window.scrollTo(0, lockedScrollY);
        }
      };

      trigger.addEventListener("click", () => {
        const shouldOpen = trigger.getAttribute("aria-expanded") !== "true";
        setOpen(shouldOpen);
      });

      panel.querySelector("[data-intro-close]")?.addEventListener("click", () => {
        setOpen(false);
        trigger.focus({ preventScroll: true });
      });

      document.querySelector("[data-intro-close-overlay]")?.addEventListener("click", () => {
        setOpen(false);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && trigger.getAttribute("aria-expanded") === "true") {
          setOpen(false);
          trigger.focus({ preventScroll: true });
        }
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupIntroPanels, { once: true });
  } else {
    setupIntroPanels();
  }
</script>
