---
import StagePanel from "./StagePanel.astro";

type IntroSection = {
  title: string;
  paragraphs: string[];
};

type Resource = {
  label: string;
  url: string;
  note?: string;
};

type Group = {
  title: string;
  description?: string | string[];
  items?: string[];
  resources?: Resource[];
};

type Subtopic = {
  id: string;
  title: string;
  color?: string;
};

const { id, title, summary, sections = [], groups = [], subtopics = [], defaultOpen = false } = Astro.props as {
  id: string;
  title?: string;
  summary?: string;
  sections?: IntroSection[];
  groups?: Group[];
  subtopics?: Subtopic[];
  defaultOpen?: boolean;
};
---

<section class={`intro-popover ${defaultOpen ? "is-open" : ""}`} id={id} data-intro-panel data-open={String(defaultOpen)} aria-hidden={!defaultOpen}>
  <button class="intro-popover-close" type="button" aria-label="收起详情侧边栏" data-intro-close>
    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m6 6 12 12M18 6 6 18" /></svg>
  </button>

  <div class="intro-popover-body">
    {(title || summary) && (
      <section class="intro-section intro-overview">
        {title && <h2>{title}</h2>}
        {summary && <p class="intro-lead">{summary}</p>}
      </section>
    )}

    {sections.map((section, sectionIndex) => (
      <section class="intro-section">
        <h2>{section.title}</h2>
        {section.paragraphs.map((paragraph, paragraphIndex) => (
          <p class={sectionIndex === 0 && paragraphIndex === 0 ? "intro-lead" : ""}>
            {paragraph}
          </p>
        ))}
      </section>
    ))}

    {(groups.length > 0 || subtopics.length > 0) && <StagePanel stage={{ id, groups, subtopics }} />}
  </div>
</section>
