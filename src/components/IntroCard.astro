---
import StagePanel from "./StagePanel.astro";

type IntroSection = {
  title: string;
  paragraphs: string[];
};

type Resource = {
  label: string;
  url: string;
  note?: string;
};

type Group = {
  title: string;
  description?: string | string[];
  items?: string[];
  resources?: Resource[];
};

type Subtopic = {
  id: string;
  title: string;
  color?: string;
};

const { id, title, summary, sections = [], groups = [], subtopics = [], defaultOpen = false } = Astro.props as {
  id: string;
  title?: string;
  summary?: string;
  sections?: IntroSection[];
  groups?: Group[];
  subtopics?: Subtopic[];
  defaultOpen?: boolean;
};

const isArticlePanel = sections.length > 0;
const contactEmail = "heheer@zju.edu.cn";
const renderParagraphParts = (paragraph: string) =>
  paragraph.split(contactEmail).flatMap((part, index, parts) => {
    const nodes: Array<{ type: "text" | "email"; text: string }> = [];
    if (part) nodes.push({ type: "text", text: part });
    if (index < parts.length - 1) nodes.push({ type: "email", text: contactEmail });
    return nodes;
  });
---

<section class={`intro-popover ${isArticlePanel ? "is-article-panel" : ""} ${defaultOpen ? "is-open" : ""}`} id={id} data-intro-panel data-open={String(defaultOpen)} aria-hidden={!defaultOpen}>
  <button class="intro-popover-close" type="button" aria-label="收起详情侧边栏" data-intro-close>
    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m6 6 12 12M18 6 6 18" /></svg>
  </button>

  <div class="intro-popover-body">
    {(title || summary) && (
      <section class="intro-section intro-overview">
        {title && <h2>{title}</h2>}
        {summary && <p class="intro-lead">{summary}</p>}
      </section>
    )}

    {sections.map((section) => (
      <section class="intro-section intro-essay">
        <div class="intro-section-heading">
          <h2>{section.title}</h2>
        </div>
        <div class="intro-paragraph-stack">
          {section.paragraphs.map((paragraph) => (
            <p>
              {renderParagraphParts(paragraph).map((part) =>
                part.type === "email" ? <a href={`mailto:${part.text}`}>{part.text}</a> : part.text
              )}
            </p>
          ))}
        </div>
      </section>
    ))}

    {(groups.length > 0 || subtopics.length > 0) && <StagePanel stage={{ id, groups, subtopics }} />}
  </div>
</section>
