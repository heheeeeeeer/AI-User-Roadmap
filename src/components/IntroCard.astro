---
import StagePanel from "./StagePanel.astro";

type IntroSection = {
  title: string;
  paragraphs: string[];
};

type Resource = {
  label: string;
  url: string;
  note?: string;
};

type Group = {
  title: string;
  items?: string[];
  resources?: Resource[];
};

const { id, title, summary, sections = [], groups = [] } = Astro.props as {
  id: string;
  title?: string;
  summary?: string;
  sections?: IntroSection[];
  groups?: Group[];
};
---

<aside class="intro-popover" id={id} data-intro-panel data-open="false" aria-hidden="true">
  <button class="intro-popover-close" type="button" aria-label="收起详情侧边栏" data-intro-close>
    ×
  </button>

  <div class="intro-popover-body">
    {(title || summary) && (
      <section class="intro-section intro-overview">
        {title && <h2>{title}</h2>}
        {summary && <p class="intro-lead">{summary}</p>}
      </section>
    )}

    {sections.map((section, sectionIndex) => (
      <section class="intro-section">
        <h2>{section.title}</h2>
        {section.paragraphs.map((paragraph, paragraphIndex) => (
          <p class={sectionIndex === 0 && paragraphIndex === 0 ? "intro-lead" : ""}>
            {paragraph}
          </p>
        ))}
      </section>
    ))}

    {groups.length > 0 && <StagePanel stage={{ id, groups }} inlineResources />}
  </div>
</aside>
