---
import ResourceList from "./ResourceList.astro";

type Resource = {
  label: string;
  url: string;
  note?: string;
};

type Group = {
  title: string;
  description?: string | string[];
  items?: string[];
  toolResources?: Resource[];
  resources?: Resource[];
};

type Subtopic = {
  id: string;
  title: string;
  color?: string;
};

type Stage = {
  id?: string;
  summary?: string;
  groups?: Group[];
  subtopics?: Subtopic[];
};

const { stage } = Astro.props as {
  stage: Stage;
};

const groupCount = stage.groups?.length ?? 0;
---

<div class="stage-groups">
  {Boolean(stage.subtopics?.length) && (
    <section class="group-card capability-card">
      <div class="capability-grid">
        {stage.subtopics?.map((topic) => (
          <button
            class={`capability-button tone-${topic.color || "green"}`}
            type="button"
            aria-expanded="false"
            aria-controls={`intro-panel-${topic.id}`}
            data-intro-trigger
          >
            {topic.title}
          </button>
        ))}
      </div>
    </section>
  )}

  {stage.groups?.map((group: Group) => (
    <section class={`group-card ${group.resources || group.toolResources ? "resource-group-card" : ""}`}>
      {(!(group.resources || group.toolResources) || groupCount > 1) && (
        <div class="group-card-heading">
          <h2>{group.title}</h2>
        </div>
      )}
      {group.description && (
        <div class="group-description">
          {(Array.isArray(group.description) ? group.description : [group.description]).map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      )}
      {group.items && (
        <div class="chip-grid">
          {group.items.map((item: string) => <span>{item}</span>)}
        </div>
      )}
      {group.toolResources && (
        <div class="resource-panel is-compact">
          <ResourceList resources={group.toolResources} />
        </div>
      )}
      {group.resources && (
        <div class:list={["resource-panel", { "is-compact": group.resources.length > 1 && group.resources.every((resource) => !resource.note) }]}>
          <ResourceList resources={group.resources} />
        </div>
      )}
    </section>
  ))}
</div>
